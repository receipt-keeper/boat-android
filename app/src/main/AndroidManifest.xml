<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 카메라 (영수증 촬영) -->
    <!-- 갤러리 선택은 Photo Picker를 사용하므로 미디어 읽기 권한이 필요 없음 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- 알림 표시 권한 (Android 13+, 런타임 다이얼로그) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 정확한 시각 알람 권한 (Android 12+, "알람 및 리마인더" 설정 화면) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- 재부팅 후 AlarmManager 알람 재등록 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".AppCore"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Boat">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Boat">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".feature.home.HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.notification.NotificationSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.receipt.ReceiptRegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.receipt.ReceiptManualInputActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.receipt.OcrResultActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.receipt.ReceiptDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.receipt.ReceiptEditActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.receipt.ReceiptRegisterCompleteActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.receipt.SearchActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.notification.NotificationListActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <!-- 푸시 알림 탭 트램폴린 — 화면 없이 읽음 처리 + 딥링크 이동만 수행 -->
        <activity
            android:name=".feature.terms.TermsDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.terms.PrivacyPolicyDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.terms.MarketingConsentDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Boat" />

        <activity
            android:name=".feature.notification.PushNotificationRouterActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <!-- AS 만료 알람 수신 -->
        <receiver
            android:name=".core.notification.AlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.windrr.boat.ACTION_WARRANTY_REMINDER" />
            </intent-filter>
        </receiver>

        <!-- 재부팅 후 알람 재등록 -->
        <receiver
            android:name=".core.notification.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- FCM 수신 -->
        <service
            android:name=".core.notification.BoatFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- 앱이 백그라운드/종료 상태일 때 시스템이 자동 표시하는 알림의 기본 아이콘/색상 -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="general_push" />

        <!-- Google AdMob Application ID (테스트용 ID) -->
        <!-- 실 서비스 시 AdMob 콘솔에서 발급받은 ID로 교체 필요 -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3833104326342504~4284779803" />

        <!-- 카메라 촬영 임시 파일 공유용 FileProvider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>